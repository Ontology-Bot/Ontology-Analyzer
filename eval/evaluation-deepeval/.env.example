DEEPEVAL_PORT=8000 # will be overwritten by top level .env
DEEPEVAL_DISABLE_TIMEOUTS=1 # api can respond very long, trust the process

SUBJECT_LLM_PROVIDER=openai
SUBJECT_LLM_BASE_URL=http://host.docker.internal:3000/api
SUBJECT_LLM_API_KEY=

JUDGE_LLM_PROVIDER=
JUDGE_LLM_BASE_URL=
JUDGE_LLM_API_KEY=
# evaluation results will be saved there
DEEPEVAL_RESULTS_FOLDER=./data
# optional
CONFIDENT_API_KEY=
